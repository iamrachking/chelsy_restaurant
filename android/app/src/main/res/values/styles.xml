<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--  LaunchTheme: Thème de démarrage (peut rester en Theme.Light.NoTitleBar) -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>

    <!--  NormalTheme: DOIT utiliser Theme.AppCompat (REQUIS pour Stripe) -->
    <style name="NormalTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>

    <!--  StripeActivityTheme: Pour les activités Stripe -->
    <style name="StripeActivityTheme" parent="Theme.AppCompat.Light">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>
    </style>
</resources>